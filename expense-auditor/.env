# Application settings
PROJECT_NAME=FastAPI App
SECRET_KEY=change-me-in-production

# API settings
API_V1_STR=/api/v1

# CORS settings
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Database settings
DATABASE_URL=sqlite:///./expense_auditor.db

